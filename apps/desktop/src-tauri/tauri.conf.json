{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "prismatic",
  "version": "0.1.0",
  "identifier": "com.patrick.prismatic",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "prismatic",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Patrick-Batenburg/prismatic/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdFOTI1Mjk1RkE2QzEzRkEKUldUNkUyejZsVktTZm9NY3NRZjJjODYyYUdWZWRYU3hGUDE3Slk4bUZnR2pzbXZhOThWYVBYejQK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "deb", "rpm", "appimage"],
    "licenseFile": "wix/license.rtf",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {}
    },
    "linux": {
      "deb": {
        "desktopTemplate": null
      },
      "rpm": {
        "release": "1"
      },
      "appimage": {}
    }
  }
}
